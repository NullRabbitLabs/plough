# =========================================================
# Validator Monitor — Environment Variables
# Copy to .env and fill in your values.
# =========================================================

# ---------------------------------------------------------
# Alerting — Telegram
# At least one of Telegram or Slack must be configured.
# ---------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-100your-chat-id

# ---------------------------------------------------------
# Alerting — Slack (optional)
# ---------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ---------------------------------------------------------
# Quiet Hours (optional)
# Suppress non-critical alerts between these UTC hours.
# Set both or neither. E.g. 23 and 7 → quiet 23:00–07:00.
# ---------------------------------------------------------
# QUIET_HOURS_START=23
# QUIET_HOURS_END=7

# ---------------------------------------------------------
# Ethereum
# ---------------------------------------------------------
# beaconcha.in API for validator metadata (optional key)
ETH_BEACON_API_URL=https://beaconcha.in
ETH_BEACON_API_KEY=

# Consensus-layer beacon node (supports public nodes)
ETH_BEACON_NODE_URL=https://ethereum-beacon-api.publicnode.com

# How many finalized slots to scan per poll cycle (default: 32 ≈ 6.4 min)
ETH_MAX_SLOTS_PER_POLL=32

# Seconds between ETH poll cycles
POLL_INTERVAL_ETH=60

# Cooldown between repeated alerts for the same validator
ETH_COOLDOWN_SECONDS=3600

# ---------------------------------------------------------
# Solana
# getVoteAccounts is blocked on most free public RPCs.
# Get a free key at https://helius.dev
# ---------------------------------------------------------
SOL_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key

# Only alert for validators with at least this much stake (SOL)
SOL_STAKE_THRESHOLD_SOL=100

# If this many validators go delinquent at once, send a single summary alert
SOL_MASS_EVENT_THRESHOLD=5

# Seconds between SOL poll cycles
POLL_INTERVAL_SOL=30

# Cooldown between repeated alerts for the same validator
SOL_COOLDOWN_SECONDS=3600

# ---------------------------------------------------------
# Sui
# ---------------------------------------------------------
SUI_RPC_URL=https://fullnode.mainnet.sui.io

# Alert when a validator's stake drops by more than this fraction (0.20 = 20%)
SUI_STAKE_DROP_THRESHOLD=0.20

# Seconds between Sui poll cycles
POLL_INTERVAL_SUI=60

# Cooldown between repeated alerts for the same validator
SUI_COOLDOWN_SECONDS=3600

# ---------------------------------------------------------
# Storage
# ---------------------------------------------------------
# Path to the JSON file used to persist state across restarts
STATE_PATH=state.json

# Path to the JSON file mapping validator indices to operator names
# See known_operators.json.example for the format
OPERATORS_PATH=known_operators.json
